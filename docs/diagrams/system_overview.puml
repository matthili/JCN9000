@startuml system_overview
' Gesamt-Architektur / system architecture: vom Code im Repo bis zur Web-App.
' Rendern: java -DPLANTUML_LIMIT_SIZE=16384 -jar plantuml.jar docs/diagrams/system_overview.puml

title JCN9000 -- system architecture

skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Helvetica"
skinparam roundCorner 8
skinparam shadowing false

skinparam rectangle {
  BackgroundColor<<engine>>     #DCE7F1
  BackgroundColor<<player>>     #E2EFDA
  BackgroundColor<<training>>   #FFF2CC
  BackgroundColor<<release>>    #FCE4D6
  BackgroundColor<<external>>   #EDEDED
  BorderColor #555555
}

rectangle "**Game engine**\n(jass_engine/)\n* 36 cards, all variants\n* Kreuz / Solo / Bodensee\n* rules, tricks, Weisen, Matsch" <<engine>> as engine

rectangle "RandomPlayer" <<player>> as random
rectangle "**HeuristicPlayer**\n* stechen / schmieren / sparen\n* tuned announcement\n* ships as \"Medium\" opponent" <<player>> as heuristic
rectangle "**NNPlayer x3**\n* one model per variant\n* loads .keras / TF.js\n* greedy over legal mask" <<player>> as nn

rectangle "**MCTS teacher + datagen**\n(training/data/)\n* determinized lookahead\n* void-aware distribution\n* full-round (Bodensee)\n* ~2M samples / round" <<training>> as datagen
rectangle "**Behavioral cloning**\n(training/train.py)\n* MLP 768/768/384\n* warm-start, 3 rounds\n* shard streaming" <<training>> as train
rectangle "**Evaluation**\n(evaluation/)\n* paired-eval\n* batched-gpu inference\n* win-rate + Elo" <<training>> as eval

rectangle "**make_release.py**\n* tests + spec-drift\n* ZIP with MANIFEST\n* gh release create" <<release>> as makerelease
rectangle "**GitHub Actions:\nadd_tfjs.yml**\n* Ubuntu runner\n* TensorFlow.js convert\n* ZIP asset --clobber" <<release>> as actions
rectangle "**GitHub release**\n* tag v0.x.2\n* ZIP: Keras + TF.js + spec" <<release>> as release

rectangle "**Web app** (separate repo)\n* \"Heb ab!\"\n* TF.js inference in browser\n* live multiplayer platform" <<external>> as webapp

engine --> random
engine --> heuristic
engine --> nn

heuristic --> datagen : "announces +\nbootstrap teacher"
nn --> datagen : "warm-start teacher\n(rounds 1-3)"
datagen --> train : "shards (.npz)"
train --> nn : "models/<variant>_mcts3/best.keras"

nn --> eval
heuristic --> eval : "baseline"

train --> makerelease : "best.keras"
makerelease --> release : "ZIP (no TF.js) +\nrelease notes"
release --> actions : "release:published"
actions --> release : "ZIP with TF.js\n(--clobber)"

release --> webapp : "gh release download"

note right of datagen
  Per position, the teacher plays
  many determinized rollouts and
  picks the highest expected-score
  card as the training label.
  Void-aware: never deals trumps to
  provably void opponents.
  Bodensee plans the whole round,
  not just one trick.
end note

note right of actions
  TF.js conversion runs on Ubuntu --
  tensorflowjs is hard to install on
  Windows/Python 3.13. The Linux
  runner uses Python 3.12.
end note

@enduml
